{
  "name": "emoji-extension",
  "version": "1.2.9-patch-3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build.js dev",
    "watch": "node scripts/watch.js",
    "build": "node scripts/build.js build",
    "build:prod": "node scripts/build.js build:prod",
    "build:minimal": "node scripts/build.js build:minimal",
    "build:debug": "node scripts/build.js build:debug",
    "build:perf": "node scripts/build.js build:perf",
    "perf": "node scripts/build.js build:perf && node scripts/performance/audit-extension.js --check",
    "perf:audit": "node scripts/performance/audit-extension.js",
    "perf:check": "node scripts/performance/audit-extension.js --check",
    "test:performance": "node --test scripts/performance/*.test.mjs",
    "serve": "vite preview",
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:extension": "playwright test --config=playwright.extension.config.ts",
    "test:extension:debug": "playwright test --config=playwright.extension.config.ts --debug",
    "release": "bash ./scripts/release.sh",
    "pack:crx": "node ./scripts/pack-crx.js",
    "pack:xpi": "node ./scripts/pack-xpi.js",
    "pack:zip": "node ./scripts/pack-zip.js",
    "pack:all": "./scripts/npm-run.sh npm run pack:crx && ./scripts/npm-run.sh npm run pack:xpi && ./scripts/npm-run.sh npm run update:data",
    "key:generate": "node scripts/generate-key.js",
    "key:backup": "cp extension-key.pem extension-key.pem.backup.$(date +%Y%m%d-%H%M%S) && echo '密钥已备份'",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "vue-tsc --noEmit",
    "prepare:json": "node scripts/prepare-json-assets.js",
    "update:data": "cd scripts/cfworker && wrangler pages deploy",
    "update:metadata": "node scripts/update-market-metadata.js",
    "update:push": "git push",
    "update:deploy": "./scripts/deploy-update.sh",
    "update:all": "npm run build:prod && npm run pack:all && npm run update:deploy",
    "release:all": "node scripts/release-all.js",
    "update:wasm": "bash ./scripts/wasm/build.sh",
    "share": "node ./scripts/collaborative-upload-server/server.js",
    "avif": "node ./scripts/webm-to-avif-backend/server.js",
    "share:stop": "kill $(lsof -t -i:9527) 2>/dev/null || echo 'Server not running'",
    "mcp": "node ./scripts/mcp-server.js",
    "mcp:stop": "kill $(lsof -t -i:7465) 2>/dev/null || echo 'MCP server not running'",
    "check:all": "pnpm lint && pnpm format:check && pnpm type-check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@bbob/core": "^4.3.1",
    "@bbob/html": "^4.3.1",
    "@bbob/parser": "^4.3.1",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/core-mt": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@jsquash/avif": "^2.1.1",
    "@mariozechner/pi-agent-core": "0.73.1",
    "@mariozechner/pi-ai": "0.73.1",
    "@opentelemetry/api": "^1.9.1",
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.21",
    "dexie": "^4.4.4",
    "dompurify": "^3.4.12",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "libheif-js": "^1.19.8",
    "lottie-web": "^5.13.0",
    "marked": "^18.0.6",
    "nanoid": "^6.0.0",
    "pinia": "^4.0.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.5",
    "prosemirror-model": "^1.25.11",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.1",
    "rehype": "^13.0.2",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "typeit": "^8.8.7",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/chrome": "^0.2.2",
    "@types/hast": "^3.0.5",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.5.3",
    "crx3": "^2.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "less": "^4.6.7",
    "lightningcss": "^1.32.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  },
  "languages": [
    "zh",
    "en"
  ],
  "bundleDependencies": [],
  "packageManager": "pnpm@11.3.0"
}
